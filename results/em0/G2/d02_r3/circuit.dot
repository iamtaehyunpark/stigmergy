digraph circuit {
  rankdir=LR;
  compound=true;
  node [fontname="Helvetica", fontsize=10, style="filled,rounded"];
  edge [fontname="Helvetica", fontsize=8, color="#888888"];
  subgraph cluster_agents { label="agents (control plane)"; color="#cccccc";
    a_root [shape=box, fillcolor="#bfe3c6", label="root\n[done]"];
    a_root_1 [shape=box, fillcolor="#bfe3c6", label="root.1\n[done]"];
    a_root_2 [shape=box, fillcolor="#bfe3c6", label="root.2\n[done]"];
    a_root_3 [shape=box, fillcolor="#bfe3c6", label="root.3\n[done]"];
    a_root_4 [shape=box, fillcolor="#bfe3c6", label="root.4\n[done]"];
    a_root_5 [shape=box, fillcolor="#bfe3c6", label="root.5\n[done]"];
  }
  a_root -> a_root_1 [style=dotted, color="#bbbbbb", arrowhead=empty];
  a_root -> a_root_2 [style=dotted, color="#bbbbbb", arrowhead=empty];
  a_root -> a_root_3 [style=dotted, color="#bbbbbb", arrowhead=empty];
  a_root -> a_root_4 [style=dotted, color="#bbbbbb", arrowhead=empty];
  a_root -> a_root_5 [style=dotted, color="#bbbbbb", arrowhead=empty];
  p_root_1_market_analysis [shape=ellipse, fillcolor="#bfe3c6", label="root.1/market_analysis\n(done)"];
  a_root_1 -> p_root_1_market_analysis [style=solid, color="#7aa7d0", arrowhead=none];
  p_root_2_competitor_analysis [shape=ellipse, fillcolor="#bfe3c6", label="root.2/competitor_analysis\n(done)"];
  a_root_2 -> p_root_2_competitor_analysis [style=solid, color="#7aa7d0", arrowhead=none];
  p_root_3_revenue_model [shape=ellipse, fillcolor="#bfe3c6", label="root.3/revenue_model\n(done)"];
  a_root_3 -> p_root_3_revenue_model [style=solid, color="#7aa7d0", arrowhead=none];
  p_root_4_go_to_market_strategy [shape=ellipse, fillcolor="#bfe3c6", label="root.4/go_to_market_strategy\n(done)"];
  a_root_4 -> p_root_4_go_to_market_strategy [style=solid, color="#7aa7d0", arrowhead=none];
  p_root_5_financial_projections [shape=ellipse, fillcolor="#bfe3c6", label="root.5/financial_projections\n(done)"];
  a_root_5 -> p_root_5_financial_projections [style=solid, color="#7aa7d0", arrowhead=none];
  p_root_business_plan [shape=ellipse, fillcolor="#bfe3c6", label="root/business_plan\n(done)"];
  a_root -> p_root_business_plan [style=solid, color="#7aa7d0", arrowhead=none];
  a_root_1 -> a_root [style=solid, color="#3a9a52", label="completed"];
  a_root_2 -> a_root [style=solid, color="#3a9a52", label="completed"];
  a_root_3 -> a_root [style=solid, color="#3a9a52", label="completed"];
  a_root_4 -> a_root [style=solid, color="#3a9a52", label="completed"];
  a_root_5 -> a_root [style=solid, color="#3a9a52", label="completed"];
  label="run d02_r3
outcome: converged
pins 6/6 done, gates 1 fired/0 dead, doctor 0"; labelloc="b"; fontsize=11;
